{
  "name": "react-native-nlp-expense",
  "version": "1.0.0",
  "description": "Lightweight offline rule-based NLP parser for React Native expense input.",
  "license": "MIT",
  "author": "Yuyutsu",

  "type": "module",

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },

  "files": [
    "dist"
  ],

  "react-native": "src/index.ts",

  "sideEffects": false,

  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },

  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },

  "dependencies": {
    "chrono-node": "^2.9.0"
  },

  "devDependencies": {
    "typescript": "^5.3.0",

    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-test-renderer": "18.3.1",

    "jest": "^29.7.0",
    "babel-jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "@types/jest": "^29.5.0",

    "@testing-library/react-native": "^12.9.0",

    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0"
  },

  "jest": {
    "preset": "react-native",
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@testing-library)/)"
    ]
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/Yuyutsu/react-native-nlp-expense.git"
  },

  "homepage": "https://github.com/Yuyutsu/react-native-nlp-expense#readme",

  "bugs": {
    "url": "https://github.com/Yuyutsu/react-native-nlp-expense/issues"
  },

  "keywords": [
    "react-native",
    "nlp",
    "expense",
    "parser",
    "typescript",
    "offline"
  ],

  "engines": {
    "node": ">=18"
  }
}